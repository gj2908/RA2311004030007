{
  "info": {
    "name": "Vehicle Maintenance Scheduler - Local",
    "_postman_id": "vehicle-scheduler-local",
    "description": "Collection to test all endpoints of vehicle_maintence_scheduler on http://localhost:3001/evaluation-service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Optimize",
      "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/optimize" }
    },
    {
      "name": "Fetch Depots",
      "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/depots" }
    },
    {
      "name": "Fetch Tasks",
      "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/tasks" }
    },
    {
      "name": "Create Vehicle",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{ \"make\": \"Toyota\", \"model\": \"Corolla\", \"year\": 2015 }" },
        "url": "{{baseUrl}}/vehicles"
      }
    },
    {
      "name": "Get All Vehicles",
      "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/vehicles" }
    },
    {
      "name": "Create Schedule",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{ \"vehicleId\": \"<vehicleId>\", \"tasks\": [] }" },
        "url": "{{baseUrl}}/schedules"
      }
    },
    {
      "name": "Get All Schedules",
      "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/schedules" }
    }
  ]
}
